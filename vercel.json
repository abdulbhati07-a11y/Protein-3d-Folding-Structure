{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/health.py": { "runtime": "python3.12" },
    "api/predictions/predict.py": { "runtime": "python3.12" },
    "api/predictions/history.py": { "runtime": "python3.12" },
    "api/predictions/[id].py": { "runtime": "python3.12" }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/predictions/predict", "dest": "/api/predictions/predict.py" },
    { "src": "/api/predictions/history", "dest": "/api/predictions/history.py" },
    { "src": "/api/predictions/history/([^/]+)", "dest": "/api/predictions/[id].py" },
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "ignoreCommand": "echo 'ignoring backend'"
}
